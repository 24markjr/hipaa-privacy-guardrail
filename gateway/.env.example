# ─────────────────────────────────────────────────────────────────────────
# AI Privacy & Compliance Gateway — example configuration
# Copy to `.env` and fill in secrets. Safe defaults let the app boot with the
# regex engine and no external services beyond Redis.
# ─────────────────────────────────────────────────────────────────────────

# ---- App ----
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_ENV=development          # development | production
LOG_LEVEL=INFO

# ---- Detection engine ----
# regex  -> fast, zero ML deps (default)
# presidio -> Microsoft Presidio + spaCy (install extras: pip install .[presidio])
DETECTION_ENGINE=regex
# Presidio only (when DETECTION_ENGINE=presidio):
PRESIDIO_SPACY_MODEL=en_core_web_lg   # use en_core_web_sm for a lighter footprint
PRESIDIO_SCORE_THRESHOLD=0.5

# ---- Compliance policy ----
# Path to the active policy profile (see gateway/policies/*.yaml)
POLICY_FILE=policies/default.yaml

# ---- LLM provider ----
LLM_PROVIDER=gemini             # gemini | openai | claude | ollama
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8
# DEEPSEEK_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# ---- Redis vault ----
REDIS_URL=redis://localhost:6379/0
VAULT_TTL_SECONDS=3600          # how long token<->original mappings live
VAULT_TOKEN_STYLE=placeholder   # placeholder (<LABEL_n>) | format_preserving
# Fernet key -> encrypts PHI at rest in Redis. REQUIRED in production.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
VAULT_ENCRYPTION_KEY=

# ---- CORS ----
# Comma-separated allowed browser origins. "*" works (auth is header-based, not cookies).
# Tighten for prod, e.g. CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173
CORS_ORIGINS=*

# ---- Auth ----
# When AUTH_MODE != none, a request is accepted with EITHER a doctor Bearer JWT
# OR a valid X-API-Key. Use 'none' only for local dev.
AUTH_MODE=api_key
# Comma-separated list of accepted API keys (service/admin clients)
API_KEYS=dev-local-key
# MUST be a strong secret in production (startup fails otherwise).
JWT_SECRET=dev-insecure-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720

# ---- Database (Neon / Postgres) ----
# Leave unset to use in-memory repositories (dev/tests only — not durable).
# Example: postgresql://user:pass@ep-xxx.aws.neon.tech/dbname?sslmode=require
NEON_DATABASE_URL=

# ---- Audit (non-blocking; written off the request path) ----
AUDIT_LOG_PATH=./data/audit.jsonl
AUDIT_QUEUE_MAXSIZE=10000

# ---- Upstream HTTP ----
UPSTREAM_TIMEOUT_SECONDS=120
UPSTREAM_MAX_RETRIES=3
